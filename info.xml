<?xml version="1.0"?>
<extension key="com.joineryhq.fbpixel" type="module">
  <file>fbpixel</file>
  <name>Facebook Pixel Tracking</name>
  <description>Inserts Facebook Pixel code on relevant CiviCRM pages and forms.</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@JoineryHQ.com</email>
  </maintainer>
  <releaseDate>2021-04-20</releaseDate>
  <version>0.3.1</version>
  <urls>
    <url desc="Main Extension Page">https://github.com/twomice/com.joineryhq.fbpixel</url>
    <url desc="Documentation">https://github.com/twomice/com.joineryhq.fbpixel</url>
    <url desc="Support">https://github.com/twomice/com.joineryhq.fbpixel/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <develStage>alpha</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments>Initial dvelopment sponsored by Rigpa, Australia.</comments>
  <civix>
    <namespace>CRM/Fbpixel</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty-v2@1.0.3</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <upgrader>CiviMix\Schema\Fbpixel\AutomaticUpgrader</upgrader>
</extension>
